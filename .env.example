# WOTANN Environment Variables
# Copy to `.env` and fill in values you need. Everything is OPTIONAL — discovery auto-detects.

# ═══ PROVIDER API KEYS ═══
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GH_TOKEN=
GITHUB_TOKEN=
CODEX_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
SAMBANOVA_API_KEY=
HUGGINGFACE_API_KEY=

# Cloud deployments
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AWS_BEDROCK_REGION=
GOOGLE_VERTEX_PROJECT=

# Local models
OLLAMA_HOST=http://localhost:11434

# ═══ CHANNEL INTEGRATIONS ═══
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
WHATSAPP_SESSION_DIR=~/.wotann/whatsapp
MATRIX_HOMESERVER_URL=
MATRIX_ACCESS_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
GITHUB_BOT_TOKEN=
IRC_SERVER=
IRC_PORT=6667
IRC_NICK=
IRC_CHANNELS=
GOOGLE_CHAT_WEBHOOK_URL=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ═══ REMOTE RELAY (iOS) ═══
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ═══ BEHAVIOR TOGGLES ═══
WOTANN_NO_TELEMETRY=0
DO_NOT_TRACK=0
WOTANN_AUTH_BYPASS=0
WOTANN_WORKSPACE_ROOT=
WOTANN_COMPANION_PORT=3849
WOTANN_DEBUG=0
