# =============================================================================
#  WOTANN — .gitignore
#  Rules are grouped by concern. When adding a new rule, include a comment
#  explaining WHY — future maintainers will thank you.
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies — never commit installed packages; they are resolved from
# package.json / Cargo.toml / Package.swift on every fresh clone.
# -----------------------------------------------------------------------------
node_modules/
.pnp/
.pnp.js
.yarn/cache/
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Build outputs — regenerated by `npm run build` / `cargo build` / Xcode.
# Shipping these in git bloats the repo and pollutes GitHub language stats.
# -----------------------------------------------------------------------------
dist/
dist-cjs/
build/
out/
coverage/
*.tsbuildinfo
*.lcov
.nyc_output/
.turbo/
.next/
.parcel-cache/
.vite/

# SEA (Single Executable Application) build artifacts
dist/release/
dist/release/*.blob
wotann-linux-*
wotann-macos-*
wotann-win-*
*.tar.gz
*.tgz
*.dmg
*.pkg
*.deb
*.rpm

# -----------------------------------------------------------------------------
# Tauri / Rust — target/ is the compile cache, often multi-GB.
# -----------------------------------------------------------------------------
desktop-app/src-tauri/target/
desktop-app/src-tauri/target-audit/
desktop-app/src-tauri/gen/
desktop-app/dist/
**/target/
**/target-audit/
Cargo.lock.bak

# -----------------------------------------------------------------------------
# iOS / Swift / Xcode — user-specific state, build caches, and secrets.
# -----------------------------------------------------------------------------
ios/build/
ios/.build/
ios/DerivedData/
ios/Local.xcconfig                       # Real local config (leaks team ID / bundle IDs)
ios/*.xcodeproj/xcuserdata/
ios/*.xcworkspace/xcuserdata/
ios/Pods/
ios/Carthage/Build/
ios/Carthage/Checkouts/
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/screenshots
ios/fastlane/test_output
*.xcuserstate

# Orphan xcodeproj bundles (xcodegen leaves these behind after regeneration)
ios/WOTANN */

# -----------------------------------------------------------------------------
# Runtime state — per-user daemon state. NEVER committed (leaks credentials,
# memory, session tokens, conversations). Full directory is ignored.
# -----------------------------------------------------------------------------
.wotann/

# -----------------------------------------------------------------------------
# Per-user caches, auth, and tool plugins (leak personal config).
# -----------------------------------------------------------------------------
.codex-home/
.superpowers/
.claude/
.cursor/
.aider*
.claude-flow/
.hive-mind/

# -----------------------------------------------------------------------------
# Environment variables and secrets — .env.example stays; real .env never does.
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test
*.pem
*.key
*.p12
*.mobileprovision
auth.json
credentials.json
anthropic-oauth.json
*.cert
*.crt

# -----------------------------------------------------------------------------
# Logs — noise, never useful in repo history.
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Databases & state files — runtime artifacts, not source.
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db
*.db-journal
*.db-wal
*.db-shm
*.pid
*.sock

# -----------------------------------------------------------------------------
# Temporary & scratch files — Finder, editors, and agent experiments.
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
.cache/
tmp/
*.output
*.trace
coredump.*
core.[0-9]*

# Scratch files used during local prompt/stream testing
/big.txt
/small.txt
/p1.txt
/p2.txt
/p3.txt

# Rescue / recovery artifacts
.git-old-corrupt-*/

# -----------------------------------------------------------------------------
# Finder-duplicate pattern — macOS Finder creates "foo 2.ts" when files
# collide on save. These are duplicates of real source files and must never
# be committed. The pattern matches any filename with " N." where N is 2-9.
# -----------------------------------------------------------------------------
*\ 2.*
*\ 3.*
*\ 4.*
*\ copy.*
*\ copy\ *.*

# -----------------------------------------------------------------------------
# Editor / IDE caches (per-user, never checked in).
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.vs/
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# OS cruft.
# -----------------------------------------------------------------------------
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Python (python-scripts/ uses virtualenvs + pycache).
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.tox/
.venv/
venv/
env/
ENV/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Large model weights / data corpora — keep these in LFS or external storage.
# -----------------------------------------------------------------------------
*.gguf
*.safetensors
*.onnx
*.pt
*.ckpt
*.bin
!scripts/release/*.bin
*.h5
*.parquet
*.arrow

# -----------------------------------------------------------------------------
# Legacy / deprecated state.
# -----------------------------------------------------------------------------
.nexus-archive/

# -----------------------------------------------------------------------------
# Internal working docs — NOT deleted, only hidden from GitHub.
# These are living audit / planning / handoff dumps that churn daily.
# Public-facing docs (AUTH, SURFACE_PARITY_REPORT, CAPABILITY_ADAPTATION_MATRIX,
# SEA_BUILD_ENVIRONMENTAL_GATE, SELF_HOSTED_RUNNER_SETUP, UI_DESIGN_SPEC)
# remain tracked under docs/.
# -----------------------------------------------------------------------------
# Dated root-level strategy/research dumps
/COMPETITIVE_INTELLIGENCE_*.md
/COMPETITOR_APP_RESEARCH_*.md
/CONTEXT_REALITY_AND_MOAT_NOTES_*.md
/FEATURE_MOAT_ROADMAP_*.md
/MARKDOWN_CORPUS_AUDIT_*.md
/RESEARCH_GAP_ANALYSIS_*.md
/SOURCES_COVERAGE_AUDIT_*.md
/SOURCE_EXTRACTION_MATRIX_*.md
/HANDOFF.md
/IMPLEMENTATION_PLAN.md

# Internal docs/ (audits, phase progress, deep-reads, session handoffs, etc.)
docs/_*.md
docs/AUDIT_*.md
docs/AUTONOMOUS_EXECUTION_PLAN*.md
docs/BENCHMARK_*.md
docs/CHANNELS_*.md
docs/CI_STATUS_*.md
docs/CLAUDE_CODE_QUICKSTART_*.md
docs/COMPETITOR_EXTRACTION_*.md
docs/competitor-research-*.md
docs/CONFIG_REALITY.md
docs/CORE_DAEMON_DEEP_READ_*.md
docs/DEAD_CODE_REPURPOSING_*.md
docs/DEEP_AUDIT_*.md
docs/DOCS_FULL_READ_SYNTHESIS_*.md
docs/FINAL_VERIFICATION_AUDIT_*.md
docs/GAP_AUDIT_*.md
docs/GIT_ARCHAEOLOGY.md
docs/HIDDEN_STATE_REPORT.md
docs/INDEX_TS_CLI_DEEP_READ_*.md
docs/IOS_SWIFT_DEEP_READ_*.md
docs/KAIROS_RPC_FULL_DEEP_READ_*.md
docs/MASTER_AUDIT_*.md
docs/MASTER_PLAN_*.md
docs/MASTER_SYNTHESIS_*.md
docs/MEMORY_ARCHAEOLOGY.md
docs/MEMORY_ORCHESTRATION_DEEP_READ_*.md
docs/NEXUS_V4_SPEC_SYNTHESIS_*.md
docs/PHASE_*.md
docs/POST_COMPACTION_HANDOFF_*.md
docs/PROMPT_LIES.md
docs/PROVIDER_HEALTH_REPORT.md
docs/PROVIDERS_MIDDLEWARE_DEEP_READ_*.md
docs/repo-updates-*.md
docs/research-repo-updates-*.md
docs/RUNTIME_TS_TAIL_DEEP_READ_*.md
docs/SESSION_*.md
docs/session-*.png
docs/SLASH_COMMAND_AUDIT.md
docs/SPEC_VS_IMPL_DIFF.md
docs/TAURI_RUST_DEEP_READ_*.md
docs/TESTS_SUSPECT.md
docs/UI_PLATFORMS_DEEP_READ_*.md
docs/UI_REALITY.md
docs/UI_UX_AUDIT.md
docs/UNKNOWN_UNKNOWNS.md
docs/UX_AUDIT_*.md
docs/WIRING_GAP_REPORT.md
docs/WOTANN_INVENTORY*
docs/WOTANN_ORPHANS*
docs/WOTANN_TEST_FLAGS*
docs/WOTANN_TESTS_INVENTORY*
docs/superpowers/

# Explicit keep-list for public docs (negated to survive broader patterns)
!docs/AUTH.md
!docs/CAPABILITY_ADAPTATION_MATRIX.md
!docs/SEA_BUILD_ENVIRONMENTAL_GATE.md
!docs/SELF_HOSTED_RUNNER_SETUP.md
!docs/SURFACE_PARITY_REPORT.md
!docs/UI_DESIGN_SPEC_*.md
