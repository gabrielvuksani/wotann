<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.wotann.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>wotann</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_wotann._tcp</string>
	</array>
	<!--
		User-facing privacy strings. Apple HARD-CRASHES the app on the
		first call to mic/camera/HealthKit/Speech/NFC if the matching
		"Why does this app need access?" string is missing. App Store
		Review (2.5.1 + 5.1.1) rejects builds without these for any API
		the binary references. See:
		- AVCaptureDevice.requestAccess(.audio) → NSMicrophoneUsageDescription
		- AVCaptureDevice.requestAccess(.video) → NSCameraUsageDescription
		- SFSpeechRecognizer / DuplexVoiceSession → NSSpeechRecognitionUsageDescription
		- HKHealthStore in HealthKitService.swift → NSHealthShareUsageDescription
		  + NSHealthUpdateUsageDescription
		- NFCNDEFReaderSession (PairingManager NFC tap) → NFCReaderUsageDescription
	-->
	<key>NSMicrophoneUsageDescription</key>
	<string>WOTANN uses your microphone for voice input — push-to-talk transcription and barge-in conversation. Audio is processed locally or via your configured provider; no recording is uploaded without your explicit action.</string>
	<key>NSCameraUsageDescription</key>
	<string>WOTANN uses the camera to scan pairing QR codes from your desktop. The camera only activates on the Pairing screen.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>WOTANN uses on-device speech recognition to transcribe your voice prompts. Transcripts stay on your device unless you choose to send them to a configured provider.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>WOTANN reads optional Health metrics (sleep, activity, focus session length) so the agent can adapt its workload to your current capacity. Sharing is opt-in per metric.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>WOTANN can write completed focus sessions back to Health when you opt in — purely for your own records, never shared off-device.</string>
	<key>NFCReaderUsageDescription</key>
	<string>WOTANN can pair with your desktop via an NFC tap. The NFC reader only activates when you choose "Pair with NFC" on the Pairing screen.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>WOTANN attaches images you pick from Photos to your conversation. Selection is per-image and stays on-device unless you send it to a provider.</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>WOTANN sends notifications when long-running tasks finish, when an approval is requested, or when a relayed task arrives from your desktop. You can disable any category in Settings.</string>
	<key>NSContactsUsageDescription</key>
	<string>WOTANN can look up contacts when you mention someone by name in a prompt — used only when you explicitly opt in to "Contact mentions" in Settings.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>WOTANN uses your location only when you opt in to location-aware automations (e.g. "remind me when I'm home"). Location is never sent off-device.</string>
	<!--
		SB-18 (Wave 5-J): iOS 18 strict ATS BLOCKS plaintext ws://localhost:* connections.
		WOTANN's phone↔desktop bridge uses unencrypted WebSocket on the LAN because
		(a) the connection is end-to-end ECDH-encrypted at the application layer
		(see Networking/RPCClient.swift + Security/ECDHManager.swift), and
		(b) certificate provisioning for ad-hoc local IPs is impractical.
		Apple's documented escape hatch is NSAllowsLocalNetworking — strictly
		narrower than NSAllowsArbitraryLoads (which we explicitly do NOT use)
		and acceptable for App Review when paired with Bonjour discovery and
		NSLocalNetworkUsageDescription (both already declared).
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!--
		Background capabilities required by shipped features:
		- remote-notification: APNs handlers in NotificationService.swift
		  + WOTANNApp.swift route push payloads while the app is suspended.
		- processing: Live Activities (NSSupportsLiveActivitiesFrequentUpdates)
		  and BGProcessingTask windows for relay/sync.
		- audio: VoiceService.swift holds an AVAudioSession during voice
		  ask + CarPlay voice control so STT/TTS survives the app moving
		  to the background.
		- fetch: opportunistic snapshot refreshes when the OS wakes us up.
	-->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>processing</string>
		<string>audio</string>
		<string>fetch</string>
	</array>
	<!--
		SB-N6 fix: every BGTaskScheduler identifier the app registers MUST
		be listed here (Apple App Review guideline 2.5.4: declared
		background modes need backing code). See BackgroundTaskCoordinator.swift
		for the registrations matching these identifiers.
	-->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.wotann.ios.offlinequeue.flush</string>
		<string>com.wotann.ios.memory.sync</string>
	</array>
	<!--
		SB-N5 fix: NSUserActivityTypes declares which user activity identifiers
		this app accepts via Continuity / Handoff / Spotlight Continue. Without
		these keys iOS rejects unknown activity types even with a registered
		`onContinueUserActivity` handler. See WOTANNApp.swift for the handler.
	-->
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.wotann.conversation</string>
		<string>com.wotann.pair</string>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>CPTemplateApplicationSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>CarPlay</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).CarPlaySceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
</dict>
</plist>
