{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WOTANN",
  "version": "0.1.0",
  "identifier": "com.wotann.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WOTANN",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://localhost:* http://localhost:* https://localhost:*; img-src 'self' data: blob:; font-src 'self' data:"
    },
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "infoPlist": "Info.plist",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": "Entitlements.plist"
    },
    "externalBin": [
      "binaries/ollama",
      "binaries/whisper"
    ]
  }
}