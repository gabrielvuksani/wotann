# Cloudflare Pages / Netlify custom HTTP headers.
# Sent on every response for paths matching the URL pattern.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://github.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/
  Cache-Control: public, max-age=300, must-revalidate

# SB-N5: Apple App Site Association — iOS universal links require
# https://wotann.com/.well-known/apple-app-site-association to return
# JSON (NOT text/html). Apple's CDN fetcher specifically checks the
# Content-Type and refuses to associate the domain if it's anything
# else. The file has no extension so Pages would otherwise hand back
# application/octet-stream.
/.well-known/apple-app-site-association
  Content-Type: application/json
  Cache-Control: public, max-age=3600
