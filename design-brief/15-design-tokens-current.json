        "3": { "$value": "0 12px 32px rgba(0,0,0,0.85), inset 0 0 0 2px rgba(209,58,42,0.45)", "$type": "shadow" },
        "glow-gold": { "$value": "0 0 24px rgba(209,58,42,0.45), 0 0 8px rgba(209,58,42,0.55)", "$type": "shadow", "$description": "Critical finding indicator" }
      }
    }
  },

  "z-index": {
    "base": { "$value": "0", "$type": "number" },
    "raised": { "$value": "10", "$type": "number" },
    "sticky": { "$value": "20", "$type": "number" },
    "header": { "$value": "30", "$type": "number" },
    "dropdown": { "$value": "40", "$type": "number" },
    "overlay": { "$value": "50", "$type": "number" },
    "modal": { "$value": "60", "$type": "number" },
    "tooltip": { "$value": "70", "$type": "number" },
    "notification": { "$value": "80", "$type": "number" },
    "max": { "$value": "9999", "$type": "number" }
  },

  "glass": {
    "$description": "Liquid Glass tokens — currently theme-agnostic in globals.css. Target: add per-theme overrides for bg/stroke/tint.",
    "bg": { "$value": "rgba(12, 17, 24, 0.6)", "$type": "color", "$description": "default (mimir)" },
    "stroke": { "$value": "rgba(138, 176, 224, 0.12)", "$type": "color" },
    "blur": { "$value": "20px", "$type": "dimension" },
    "saturate": { "$value": "1.4", "$type": "number" },
    "contrast": { "$value": "1.0", "$type": "number", "$description": "NOT YET APPLIED — add to deepen tint" },
    "noise-opacity": { "$value": "0.02", "$type": "number", "$description": "2% SVG noise overlay — NOT YET APPLIED" },
    "sheen-opacity": { "$value": "0.20", "$type": "number", "$description": "Specular gold hover sheen — NOT YET APPLIED" }
  }
