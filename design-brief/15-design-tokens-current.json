{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "WOTANN current design tokens, exported from desktop-app/src/styles/wotann-tokens.css as W3C Design Tokens Community Group format. Five themes: mimir (default dark), yggdrasil (light), runestone (marketing hero), bifrost (gradient — onboarding ONLY), valkyrie (Exploit tab ONLY). Motion + spacing + radii + typography are theme-agnostic.",
  "$version": "1.0.0",
  "$exported_from": "wotann/desktop-app/src/styles/wotann-tokens.css",
  "$exported_date": "2026-04-19",

  "motion": {
    "ease": {
      "out-expo": {
        "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "$type": "cubicBezier",
        "$description": "Default ease for reveals and slides"
      },
      "productive": {
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
        "$type": "cubicBezier",
        "$description": "Material productive — snappy for interactive"
      },
      "standard": {
        "$value": "cubic-bezier(0.4, 0.14, 0.3, 1)",
        "$type": "cubicBezier",
        "$description": "Carbon-style standard curve"
      },
      "pop": {
        "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "$type": "cubicBezier",
        "$description": "Playful bounce — use sparingly (error shake, chip pop)"
      }
    },
    "duration": {
      "instant": { "$value": "80ms", "$type": "duration", "$description": "Hover, color swap" },
      "fast": { "$value": "150ms", "$type": "duration", "$description": "Button press, state change" },
      "base": { "$value": "240ms", "$type": "duration", "$description": "Reveal, slide-in" },
      "slow": { "$value": "400ms", "$type": "duration", "$description": "Drawer, sheet" },
      "deliberate": { "$value": "600ms", "$type": "duration", "$description": "Page-level, streaming cursor loop" }
    }
  },

  "radius": {
    "sharp": { "$value": "2px", "$type": "dimension", "$description": "Rune / sigil — minimal rounding" },
    "input": { "$value": "6px", "$type": "dimension", "$description": "Input fields, small chips" },
    "panel": { "$value": "10px", "$type": "dimension", "$description": "Panels, sidebar, mid-size cards" },
    "card": { "$value": "12px", "$type": "dimension", "$description": "Feature cards, modals" },
    "pill": { "$value": "999px", "$type": "dimension", "$description": "Pill-shaped elements — use sparingly" }
  },

  "spacing": {
    "1": { "$value": "2px", "$type": "dimension" },
    "2": { "$value": "4px", "$type": "dimension" },
    "3": { "$value": "8px", "$type": "dimension" },
    "4": { "$value": "12px", "$type": "dimension" },
    "5": { "$value": "16px", "$type": "dimension" },
    "6": { "$value": "20px", "$type": "dimension" },
    "7": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "9": { "$value": "40px", "$type": "dimension" },
    "10": { "$value": "48px", "$type": "dimension" },
    "11": { "$value": "64px", "$type": "dimension" },
    "12": { "$value": "96px", "$type": "dimension" }
  },

  "typography": {
    "font-family": {
      "sans": {
        "$value": "Inter Variable, SF Pro Text, system-ui, sans-serif",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "JetBrains Mono Variable, SF Mono, ui-monospace, monospace",
        "$type": "fontFamily"
      },
      "display": {
        "$value": "Geist Sans, Inter Variable, system-ui, sans-serif",
        "$type": "fontFamily"
      },
      "rune": {
        "$value": "Noto Sans Runic, Segoe UI Symbol, system-ui, sans-serif",
        "$type": "fontFamily"
      }
    },
    "size": {
      "11": { "$value": "11px", "$type": "dimension", "$description": "Status bar, smallest labels" },
      "12": { "$value": "12px", "$type": "dimension", "$description": "Secondary labels" },
      "13": { "$value": "13px", "$type": "dimension", "$description": "Small body, chips" },
      "14": { "$value": "14px", "$type": "dimension", "$description": "Body" },
      "16": { "$value": "16px", "$type": "dimension", "$description": "Body large" },
      "18": { "$value": "18px", "$type": "dimension", "$description": "Subheading" },
      "20": { "$value": "20px", "$type": "dimension", "$description": "Card heading" },
      "24": { "$value": "24px", "$type": "dimension", "$description": "View heading" },
      "32": { "$value": "32px", "$type": "dimension", "$description": "Hero heading" },
      "48": { "$value": "48px", "$type": "dimension", "$description": "Display" },
      "64": { "$value": "64px", "$type": "dimension", "$description": "Marketing hero" }
    },
    "weight": {
      "regular": { "$value": "400", "$type": "fontWeight" },
      "medium": { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" }
    },
    "line-height": {
      "display": { "$value": "1.0", "$type": "number" },
      "body": { "$value": "1.35", "$type": "number" },
      "long-form": { "$value": "1.5", "$type": "number" }
    },
    "tracking": {
      "display": { "$value": "-0.02em", "$type": "dimension" },
      "body": { "$value": "-0.011em", "$type": "dimension" },
      "mono": { "$value": "0em", "$type": "dimension" },
      "caps": { "$value": "0.08em", "$type": "dimension", "$description": "ALL-CAPS labels" }
    },
    "feature-settings": {
      "body": { "$value": "'cv11', 'ss03'", "$type": "fontFeatureSettings" },
      "tabular": { "$value": "'tnum'", "$type": "fontFeatureSettings", "$description": "Data cells: cost, tokens, context" }
    }
  },

  "focus-ring": {
    "ring": { "$value": "2px solid {colors.mimir.accent.rune}", "$type": "border" },
    "offset": { "$value": "2px", "$type": "dimension" }
  },

  "colors": {
    "mimir": {
      "$description": "Default dark theme — deep cognition. 7.1:1 contrast on accent.rune against bg.canvas.",
      "bg": {
        "canvas": { "$value": "#07090F", "$type": "color", "$description": "iron-midnight" },
        "panel": { "$value": "#0C1118", "$type": "color" },
        "raised": { "$value": "#111823", "$type": "color" },
        "overlay": { "$value": "#18212F", "$type": "color" }
      },
      "surface": {
        "stroke": { "$value": "rgba(138, 176, 224, 0.08)", "$type": "color" }
      },
      "ink": {
        "primary": { "$value": "#E8EEF7", "$type": "color", "$description": "bone-ash; 19.5:1 on canvas" },
        "secondary": { "$value": "#9FB1C8", "$type": "color" },
        "muted": { "$value": "#5F7389", "$type": "color", "$description": "4.9:1 — needs raising to #7E91A6 for AAA 7:1" }
      },
      "accent": {
        "rune": { "$value": "#3E8FD1", "$type": "color", "$description": "wellwater — primary accent" },
        "glyph": { "$value": "#7DC4F5", "$type": "color" },
        "gold": { "$value": "#C9A14A", "$type": "color", "$description": "hearthgold — proof-sealed, premium provider" }
      },
      "warn": {
        "blood": { "$value": "#C04A3E", "$type": "color" }
      },
      "success": {
        "moss": { "$value": "#4FA37F", "$type": "color" }
      },
      "elevation": {
        "1": { "$value": "0 1px 2px rgba(0,0,0,0.35), inset 0 0 0 1px rgba(255,168,67,0.04)", "$type": "shadow" },
        "2": { "$value": "0 4px 12px rgba(0,0,0,0.45), inset 0 0 0 1px rgba(255,168,67,0.06)", "$type": "shadow" },
        "3": { "$value": "0 12px 32px rgba(0,0,0,0.55), inset 0 0 0 1px rgba(255,168,67,0.08)", "$type": "shadow" },
        "glow-gold": { "$value": "0 0 24px rgba(62,143,209,0.25)", "$type": "shadow", "$description": "Focused streaming state" }
      }
    },
    "yggdrasil": {
      "$description": "Light theme — rooted, daylight",
      "bg": {
        "canvas": { "$value": "#F3EFE6", "$type": "color", "$description": "oat-parchment" },
        "panel": { "$value": "#ECE5D5", "$type": "color" },
        "raised": { "$value": "#FFFFFF", "$type": "color" },
        "overlay": { "$value": "#F8F4EA", "$type": "color" }
      },
      "surface": {
        "stroke": { "$value": "rgba(26, 22, 18, 0.10)", "$type": "color" }
      },
      "ink": {
        "primary": { "$value": "#1A1612", "$type": "color", "$description": "bark-ink; 15.2:1 on canvas" },
        "secondary": { "$value": "#4A4035", "$type": "color" },
        "muted": { "$value": "#7A6C5E", "$type": "color" }
      },
      "accent": {
        "rune": { "$value": "#3B6B3A", "$type": "color", "$description": "mossgreen" },
        "glyph": { "$value": "#8A5A2B", "$type": "color" },
        "gold": { "$value": "#B3882F", "$type": "color" }
      },
      "warn": {
        "blood": { "$value": "#9B3A2A", "$type": "color" }
      },
      "success": {
        "moss": { "$value": "#3B6B3A", "$type": "color" }
      },
      "elevation": {
        "1": { "$value": "0 1px 2px rgba(26,22,18,0.08)", "$type": "shadow" },
        "2": { "$value": "0 4px 12px rgba(26,22,18,0.10)", "$type": "shadow" },
        "3": { "$value": "0 12px 32px rgba(26,22,18,0.12)", "$type": "shadow" },
        "glow-gold": { "$value": "0 0 24px rgba(179,136,47,0.25)", "$type": "shadow" }
      }
    },
    "runestone": {
      "$description": "High-contrast obsidian — marketing hero / demo only",
      "bg": {
        "canvas": { "$value": "#030508", "$type": "color", "$description": "volcanic" },
        "panel": { "$value": "#06090E", "$type": "color" },
        "raised": { "$value": "#0A0D15", "$type": "color" },
        "overlay": { "$value": "#0E1320", "$type": "color" }
      },
      "surface": {
        "stroke": { "$value": "rgba(201, 161, 74, 0.14)", "$type": "color", "$description": "hairline gold, 0.5px" }
      },
      "ink": {
        "primary": { "$value": "#F5F1E8", "$type": "color", "$description": "20.8:1 on canvas" },
        "secondary": { "$value": "#C9B896", "$type": "color" },
        "muted": { "$value": "#7A6B4B", "$type": "color" }
      },
      "accent": {
        "rune": { "$value": "#E8C268", "$type": "color", "$description": "primary gold" },
        "glyph": { "$value": "#8A6A2B", "$type": "color" },
        "gold": { "$value": "#E8C268", "$type": "color" }
      },
      "warn": {
        "blood": { "$value": "#D04432", "$type": "color" }
      },
      "success": {
        "moss": { "$value": "#3FA37F", "$type": "color" }
      },
      "elevation": {
        "1": { "$value": "0 1px 2px rgba(0,0,0,0.55), inset 0 0 0 1px rgba(232,194,104,0.14)", "$type": "shadow" },
        "2": { "$value": "0 4px 12px rgba(0,0,0,0.70), inset 0 0 0 1px rgba(232,194,104,0.18)", "$type": "shadow" },
        "3": { "$value": "0 12px 32px rgba(0,0,0,0.85), inset 0 0 0 1px rgba(232,194,104,0.22)", "$type": "shadow" },
        "glow-gold": { "$value": "0 0 32px rgba(232,194,104,0.35)", "$type": "shadow" }
      }
    },
    "bifrost": {
      "$description": "Gradient — onboarding + celebrations ONLY. Never a sustained work surface.",
      "bg": {
        "canvas": {
          "$value": "linear-gradient(160deg, #1B1230 0%, #3A2B55 22%, #7A3B6C 48%, #C95C5C 68%, #E8A24A 85%, #F4E6A0 100%)",
          "$type": "gradient"
        },
        "panel": { "$value": "rgba(27, 18, 48, 0.72)", "$type": "color", "$description": "+ backdrop-filter blur(24px) saturate(1.2)" },
        "raised": { "$value": "rgba(58, 43, 85, 0.78)", "$type": "color" },
        "overlay": { "$value": "rgba(27, 18, 48, 0.88)", "$type": "color" }
      },
      "surface": {
        "stroke": { "$value": "rgba(244, 230, 160, 0.20)", "$type": "color" }
      },
