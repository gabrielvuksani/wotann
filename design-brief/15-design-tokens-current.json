        "secondary": { "$value": "#FFE3A3", "$type": "color" },
        "muted": { "$value": "#D9B680", "$type": "color" }
      },
      "accent": {
        "rune": { "$value": "#FFE3A3", "$type": "color" },
        "glyph": { "$value": "#FFBE6E", "$type": "color" },
        "gold": { "$value": "#E8A24A", "$type": "color" },
        "prism": {
          "$value": "conic-gradient(from 210deg, #5EC8F0, #9B6BF0, #F06BA0, #F0B85E, #6BF0B5, #5EC8F0)",
          "$type": "gradient"
        }
      },
      "warn": {
        "blood": { "$value": "#E5484D", "$type": "color" }
      },
      "success": {
        "moss": { "$value": "#4CC38A", "$type": "color" }
      },
      "elevation": {
        "1": { "$value": "0 1px 2px rgba(0,0,0,0.35)", "$type": "shadow" },
        "2": { "$value": "0 4px 16px rgba(0,0,0,0.45)", "$type": "shadow" },
        "3": { "$value": "0 12px 40px rgba(0,0,0,0.55)", "$type": "shadow" },
        "glow-gold": { "$value": "0 0 32px rgba(255,227,163,0.45)", "$type": "shadow" }
      }
    },
    "valkyrie": {
      "$description": "Battle-ready — Exploit tab ONLY. Auto-activates on tab enter.",
      "bg": {
        "canvas": { "$value": "#0A0808", "$type": "color" },
        "panel": { "$value": "#141010", "$type": "color" },
        "raised": { "$value": "#1C1414", "$type": "color" },
        "overlay": { "$value": "#221616", "$type": "color" }
      },
      "surface": {
        "stroke": { "$value": "#2A1C1C", "$type": "color" }
