        "secondary": { "$value": "#B8A89C", "$type": "color" },
        "muted": { "$value": "#7A6A60", "$type": "color" }
      },
      "accent": {
        "rune": { "$value": "#D13A2A", "$type": "color", "$description": "blood primary" },
        "glyph": { "$value": "#8FA0AE", "$type": "color", "$description": "steel" },
        "gold": { "$value": "#E8A344", "$type": "color" }
      },
      "warn": {
        "blood": { "$value": "#D13A2A", "$type": "color" }
      },
      "success": {
