<?xml version="1.0" encoding="utf-8"?>
<!--
  WOTANN Android manifest — V9 FT.3.3 scaffold.

  WHAT: Declares the WotannApplication, MainActivity, foreground
    services (agent + voice), Glance widgets, the Quick Settings
    Tile, and the share intent.

  WHY: The manifest is the contract between the app and the OS. All
    of the V9 §FT.3.3 features — agent foreground service, three
    Glance widgets, QS tile, share-target intent, biometric unlock —
    require explicit declarations here.

  WHERE: Read by AGP at build time. Merged into the final APK
    manifest (with manifest from any aar deps) by the manifest merger.

  HOW:
    - permission declarations are minimal — every permission must
      justify itself in code comments below
    - foreground-service types declared per Android 14 rules
      (MEDIA_PLAYBACK for voice, DATA_SYNC for the agent loop)
    - exported flags explicit on all components (Android 12+ rule)
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Permissions ───────────────────────────────────────────
         Each permission is annotated with WHY and WHEN. -->

    <!-- Networking — WebSocket bridge to the desktop engine. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- LAN discovery via NSD (Bonjour/mDNS) — pairing wizard step. -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Foreground services — required for sustained agent loops
         and voice mode that survive screen-off. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Wake-lock — needed during a foreground service so the OS
         doesn't doze the radio when the screen is off. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Notifications — required for foreground-service notifications
         on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Biometric — pairing-token unlock. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Camera — QR pairing. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- NFC — optional; used for tap-to-pair on devices that have it. -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature android:name="android.hardware.nfc" android:required="false" />

    <!-- Vibration — haptic feedback for chat send / completion. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Quick Settings tile — already implied, but call it out. -->
    <uses-permission android:name="android.permission.BIND_QUICK_SETTINGS_TILE"
        tools:ignore="ProtectedPermissions" />

    <!-- ── Application ──────────────────────────────────────────── -->
    <application
        android:name=".WotannApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Wotann.Splash"
        tools:targetApi="34">

        <!-- ── MainActivity ────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|keyboard|navigation|screenLayout|uiMode|fontScale|fontWeightAdjustment|density|locale|layoutDirection"
            android:theme="@style/Theme.Wotann.Splash">

            <!-- Standard launcher entry. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Share-target intent — opens text shared from any
                 app directly into the Chat tab. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <!-- wotann:// URL scheme — used by relay deep-links. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="wotann" />
            </intent-filter>
        </activity>

        <!-- ── Foreground services ─────────────────────────────── -->
        <service
            android:name=".services.AgentForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:description="@string/agent_service_description" />

        <service
            android:name=".services.VoiceService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback"
            android:description="@string/voice_service_description" />

        <!-- ── Quick Settings Tile ─────────────────────────────── -->
        <service
            android:name=".tile.WotannTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_wotann"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
            <meta-data
                android:name="android.service.quicksettings.TOGGLEABLE_TILE"
                android:value="true" />
        </service>

        <!-- ── Glance widgets ──────────────────────────────────── -->
        <receiver
            android:name=".widgets.CostWidgetReceiver"
            android:exported="false"
            android:label="@string/widget_cost_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_cost_info" />
        </receiver>

        <receiver
            android:name=".widgets.AgentStatusWidgetReceiver"
            android:exported="false"
            android:label="@string/widget_status_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_agent_status_info" />
        </receiver>

        <receiver
            android:name=".widgets.QuickLaunchWidgetReceiver"
            android:exported="false"
            android:label="@string/widget_quicklaunch_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quicklaunch_info" />
        </receiver>

    </application>

</manifest>
