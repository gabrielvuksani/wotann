<?xml version="1.0" encoding="utf-8"?>
<!--
  V9 FT.3.3 data extraction rules.

  WHAT: Declares which app data is included in cloud backup and
    device-to-device transfer.

  WHY: Required by AndroidManifest.xml's android:dataExtractionRules.
    Android 12+ uses these rules to decide what's included in
    auto-backup.

  HOW: We exclude EVERYTHING by default. The pairing token, cached
    chats, and queued offline commands are all sensitive and MUST
    NOT leave the device via auto-backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
